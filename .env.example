# Example .env for Patch Validator
PATCHING_API_URL=https://api.example.com
PATCHING_API_KEY=
DB_PATH=./data/patches.db
LOG_LEVEL=INFO
LOOKUP_CACHE_TTL_SECONDS=300

# Cisco DNA Center (DNAC) credentials and endpoints by region
# Shared username/password for all regions; tokens may differ per region.
DNA_USERNAME=
DNA_PASSWORD=
DNAC_VERIFY_SSL=true
SSH_DEVICE_TYPE=cisco_ios
SSH_TIMEOUT_SECONDS=12

# EMEA -> DNAC AMES
EMEA_DNAC_BASE_URL=
EMEA_DNAC_TOKEN=

# US -> DNAC WEST
US_DNAC_BASE_URL=
US_DNAC_TOKEN=

# APAC -> DNAC EAST
APAC_DNAC_BASE_URL=
APAC_DNAC_TOKEN=

# Outlook integration for upgrade notification parsing (Windows + pywin32)
OUTLOOK_ENABLED=true
OUTLOOK_MAILBOX=
OUTLOOK_FOLDER=Inbox
OUTLOOK_LOOKBACK_HOURS=24
OUTLOOK_MAX_MESSAGES=200
OUTLOOK_SUBJECT_CONTAINS=Cisco IOS upgrade report results
OUTLOOK_SENDER_CONTAINS=network-upgrade-reports@digitalrealty.com
OUTLOOK_BODY_CONTAINS=
OUTLOOK_TO_CONTAINS=
